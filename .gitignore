.DS_Store

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json
client_secret_*.json

# Node
node_modules/
dist/
build/
*.tsbuildinfo

# Stray compiled artifacts inside src/ trees (tsconfigs compile to dist/ or are
# re-emitted alongside sources). Keep .ts as the source of truth.
**/src/**/*.js
**/src/**/*.d.ts
**/src/**/*.js.map
**/src/**/*.d.ts.map

# Databases and local state
*.db
*.db-journal
*.db-wal
*.db-shm
quill.db*

# Editor / tooling caches (committed selectively)
.cursor/plans/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
